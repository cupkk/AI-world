# ============================================================================
# AI-World Backend - Environment Variables
# Copy to .env.local for local development
# ============================================================================

# --- Core ---
NODE_ENV=development
API_PORT=3000

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL="postgresql://aiworld:aiworld_dev@localhost:5432/aiworld?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Session ---
SESSION_SECRET="change-this-to-a-random-64-char-string-in-production"

# --- CORS ---
CORS_ORIGIN="http://localhost:5173"

# --- Alibaba Cloud OSS ---
OSS_REGION="oss-cn-shanghai"
OSS_ENDPOINT="oss-cn-shanghai.aliyuncs.com"
OSS_BUCKET="aiworld-kb-dev"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
UPLOAD_DIR="uploads"
# Production: use RAM role ARN instead of AK/SK
# OSS_ROLE_ARN="acs:ram::xxx:role/oss-access"

# --- Mail / Password Reset ---
# Production example: APP_URL="https://ai-world.asia"
APP_URL="https://ai-world.asia"
MAIL_FROM="AI-World <noreply@ai-world.asia>"
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
# Rotate any previously exposed SMTP credentials before the next release.

# Optional: comma separated reusable demo invite codes for local/dev environments only.
# Production ignores these values even if they are set.
ENABLE_DEMO_INVITES=""
DEMO_INVITE_CODES=""

# Public sample invites that can be shown on the invite/login pages.
# Format: ROLE:CODE,ROLE:CODE (example: EXPERT:AIWORLD-EXPERT-2026)
ENABLE_PUBLIC_SAMPLE_INVITES="true"
PUBLIC_SAMPLE_INVITES="EXPERT:AIWORLD-EXPERT-2026,LEARNER:AIWORLD-LEARNER-2026,ENTERPRISE_LEADER:AIWORLD-ENTERPRISE-2026"

# Launch-gated features. In production, set explicitly instead of relying on defaults.
ENABLE_ASSISTANT="true"
ENABLE_KNOWLEDGE_BASE="true"

# --- LLM (AI Recommendation) ---
# Supported: openai, qwen
LLM_PROVIDER="openai"
LLM_API_KEY=""
LLM_CHAT_MODEL="gpt-4o"
OPENAI_BASE_URL="https://api.openai.com/v1"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
REQUIRE_LLM=""

# --- Embedding Model ---
# OpenAI: text-embedding-3-small, text-embedding-3-large
# Qwen: text-embedding-v2
EMBEDDING_MODEL="text-embedding-3-small"

# --- Knowledge Base Worker ---
KB_QUEUE_NAME="kb:process-queue"
KB_UPLOAD_DIR="uploads-private"
# Optional AV hook. Example: KB_AV_SCAN_COMMAND="clamscan --no-summary {file}"
KB_AV_SCAN_COMMAND=""
KB_AV_SCAN_FAIL_OPEN=""
KB_AV_SCAN_TIMEOUT_MS="15000"

# --- Strict production dependencies ---
REQUIRE_OSS=""
OSS_PUBLIC_BASE_URL=""
REQUIRE_SMTP=""

# --- Seed controls ---
SEED_INCLUDE_DEMO_DATA=""
# Production ignores SEED_INCLUDE_DEMO_DATA even if it is set.
# Production requires an explicit admin password only when creating the admin user for the first time.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_DISPLAY_NAME=""
SEED_ADMIN_HEADLINE=""
SEED_ADMIN_PASSWORD=""
SEED_FORCE_RESET_ADMIN_PASSWORD=""

# --- Logging ---
LOG_LEVEL="debug"

# --- Observability ---
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
APP_VERSION="1.0.0"
