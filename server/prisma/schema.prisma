// ============================================================================
// AI-World Database Schema
// PostgreSQL + pgvector
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public"), uuidOssp(map: "uuid-ossp", schema: "public")]
}

// ============================================================================
// Enums
// ============================================================================

enum UserRole {
  EXPERT
  ENTERPRISE_LEADER
  LEARNER
  ADMIN
}

enum UserStatus {
  pending_identity_review
  active
  suspended
}

enum InviteStatus {
  unused
  used
  revoked
}

enum ReviewStatus {
  draft
  pending_review
  published
  rejected
}

enum HubItemType {
  contest
  paper
  policy
  project
  tool
}

enum NeedVisibility {
  public_all
  experts_and_learners
}

enum ApplicationStatus {
  submitted
  accepted
  rejected
}

enum ApplicationTargetType {
  enterprise_need
  research_project
  hub_project
}

enum ConversationType {
  dm
}

enum MessageRequestStatus {
  pending
  accepted
  rejected
}

enum KbFileStatus {
  uploaded
  parsing
  embedded
  ready
  failed
}

enum EmailVisibility {
  public
  masked
  hidden
}

enum ReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

// ============================================================================
// 1. Users & Auth
// ============================================================================

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique @db.VarChar(255)
  passwordHash  String     @map("password_hash") @db.VarChar(255)
  role          UserRole
  status        UserStatus @default(pending_identity_review)
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  // Relations
  profile              Profile?
  enterpriseProfile    EnterpriseProfile?
  issuedInvites        Invite[]          @relation("InviteIssuer")
  boundInvite          Invite?           @relation("InviteBound")
  authoredHubItems     HubItem[]         @relation("HubAuthor")
  adminHubItems        HubItem[]         @relation("HubAdmin")
  enterpriseNeeds      EnterpriseNeed[]
  researchProjects     ResearchProject[]
  applications         Application[]
  sentMessages         Message[]
  conversationMembers  ConversationMember[]
  sentRequests         MessageRequest[]  @relation("RequestFrom")
  receivedRequests     MessageRequest[]  @relation("RequestTo")
  blocksGiven          UserBlock[]       @relation("Blocker")
  blocksReceived       UserBlock[]       @relation("Blocked")
  reportsSubmitted     Report[]          @relation("Reporter")
  kbFiles              KbFile[]
  kbChunks             KbChunk[]
  auditActions         AuditLog[]

  @@map("users")
}

// ============================================================================
// 2. Invites
// ============================================================================

model Invite {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String       @unique @db.VarChar(32)
  status        InviteStatus @default(unused)
  expiresAt     DateTime?    @map("expires_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Who issued it (admin)
  issuedByAdminId String?    @map("issued_by_admin_id") @db.Uuid
  issuedByAdmin   User?      @relation("InviteIssuer", fields: [issuedByAdminId], references: [id])

  // Who used it
  boundUserId   String?      @unique @map("bound_user_id") @db.Uuid
  boundUser     User?        @relation("InviteBound", fields: [boundUserId], references: [id])

  @@map("invites")
}

// ============================================================================
// 3. Profiles & Tags
// ============================================================================

model Profile {
  userId          String          @id @map("user_id") @db.Uuid
  displayName     String?         @map("display_name") @db.VarChar(100)
  avatarUrl       String?         @map("avatar_url") @db.VarChar(512)
  headline        String?         @db.VarChar(255)
  bio             String?         @db.Text
  org             String?         @db.VarChar(255)
  title           String?         @db.VarChar(255)
  location        String?         @db.VarChar(255)
  contactEmail    String?         @map("contact_email") @db.VarChar(255)
  emailVisibility EmailVisibility @default(hidden) @map("email_visibility")

  // Phone (all roles, private by default)
  phone             String?  @db.VarChar(30)
  phonePublic       Boolean  @default(false) @map("phone_public")

  // Enterprise-specific
  companyName       String?  @map("company_name") @db.VarChar(255)
  taxId             String?  @map("tax_id") @db.VarChar(100)
  businessScope     String?  @map("business_scope") @db.Text

  // Expert-specific
  researchField     String?  @map("research_field") @db.VarChar(255)
  personalPage      String?  @map("personal_page") @db.VarChar(512)
  academicTitle     String?  @map("academic_title") @db.VarChar(100)

  // Learner-specific
  major             String?  @db.VarChar(255)

  // Platform intents (selected during onboarding)
  platformIntents   Json?    @map("platform_intents")     // string[]
  onboardingDone    Boolean  @default(false) @map("onboarding_done")

  // Frontend-aligned additions
  socialLinks       Json?    @map("social_links")         // { github, linkedin, twitter, website }
  whatImDoing       String?  @map("what_im_doing") @db.Text
  whatICanProvide   String?  @map("what_i_can_provide") @db.Text
  whatImLookingFor  String?  @map("what_im_looking_for") @db.Text
  aiStrategy        String?  @map("ai_strategy") @db.Text

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id])
  profileTags ProfileTag[]

  @@map("profiles")
}

model Tag {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String       @unique @db.VarChar(50)
  createdAt DateTime     @default(now()) @map("created_at")

  profileTags  ProfileTag[]
  hubItemTags  HubItemTag[]

  @@map("tags")
}

model ProfileTag {
  profileUserId String  @map("profile_user_id") @db.Uuid
  tagId         String  @map("tag_id") @db.Uuid

  profile Profile @relation(fields: [profileUserId], references: [userId])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([profileUserId, tagId])
  @@map("profile_tags")
}

// ============================================================================
// 4. Hub (Knowledge Hub)
// ============================================================================

model HubItem {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type          HubItemType
  title         String       @db.VarChar(255)
  summary       String?      @db.Text
  contentRich   String?      @map("content_rich") @db.Text
  coverUrl      String?      @map("cover_url") @db.VarChar(512)
  sourceUrl     String?      @map("source_url") @db.VarChar(512)
  reviewStatus  ReviewStatus @default(draft) @map("review_status")
  rejectReason  String?      @map("reject_reason") @db.Text
  publishedAt   DateTime?    @map("published_at")
  likesCount    Int          @default(0) @map("likes_count")
  viewsCount    Int          @default(0) @map("views_count")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  // Author (expert/enterprise user)
  authorUserId  String?      @map("author_user_id") @db.Uuid
  author        User?        @relation("HubAuthor", fields: [authorUserId], references: [id])

  // Admin who published directly
  adminUserId   String?      @map("admin_user_id") @db.Uuid
  admin         User?        @relation("HubAdmin", fields: [adminUserId], references: [id])

  hubItemTags   HubItemTag[]

  @@index([authorUserId])
  @@index([reviewStatus])
  @@index([type])
  @@index([createdAt])
  @@map("hub_items")
}

model HubItemTag {
  hubItemId String @map("hub_item_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  hubItem HubItem @relation(fields: [hubItemId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([hubItemId, tagId])
  @@map("hub_item_tags")
}

// ============================================================================
// 5. Enterprise
// ============================================================================

model EnterpriseProfile {
  userId          String   @id @map("user_id") @db.Uuid
  aiStrategyText  String?  @map("ai_strategy_text") @db.Text
  casesText       String?  @map("cases_text") @db.Text
  achievementsText String? @map("achievements_text") @db.Text
  generatedByAi   Boolean  @default(false) @map("generated_by_ai")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("enterprise_profiles")
}

model EnterpriseNeed {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String         @db.VarChar(255)
  background      String?        @db.Text
  goal            String?        @db.Text
  deliverables    String?        @db.Text
  requiredRoles   Json?          @map("required_roles")
  visibility      NeedVisibility @default(public_all)
  reviewStatus    ReviewStatus   @default(draft) @map("review_status")
  rejectReason    String?        @map("reject_reason") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  enterpriseUserId String       @map("enterprise_user_id") @db.Uuid
  enterprise       User         @relation(fields: [enterpriseUserId], references: [id])

  @@index([enterpriseUserId])
  @@map("enterprise_needs")
}

// ============================================================================
// 6. Research Projects (Expert)
// ============================================================================

model ResearchProject {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String       @db.VarChar(255)
  summary       String?      @db.Text
  neededSupport String?      @map("needed_support") @db.Text
  tags          Json?
  reviewStatus  ReviewStatus @default(draft) @map("review_status")
  rejectReason  String?      @map("reject_reason") @db.Text
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  expertUserId  String       @map("expert_user_id") @db.Uuid
  expert        User         @relation(fields: [expertUserId], references: [id])

  @@index([expertUserId])
  @@map("research_projects")
}

// ============================================================================
// 7. Applications
// ============================================================================

model Application {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetType       ApplicationTargetType @map("target_type")
  targetId         String              @map("target_id") @db.Uuid
  message          String?             @db.Text
  status           ApplicationStatus   @default(submitted)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  applicantUserId  String              @map("applicant_user_id") @db.Uuid
  applicant        User                @relation(fields: [applicantUserId], references: [id])

  @@unique([applicantUserId, targetType, targetId])
  @@index([applicantUserId])
  @@map("applications")
}

// ============================================================================
// 8. Messaging
// ============================================================================

model Conversation {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           ConversationType @default(dm)
  lastMessageAt  DateTime?        @map("last_message_at")
  lastMessageId  String?          @map("last_message_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  members  ConversationMember[]
  messages Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  conversationId    String    @map("conversation_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  lastReadMessageId String?   @map("last_read_message_id") @db.Uuid
  lastReadAt        DateTime? @map("last_read_at")
  muted             Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bodyText       String   @map("body_text") @db.Text
  clientMsgId    String?  @map("client_msg_id") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at")

  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@unique([senderId, clientMsgId])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model MessageRequest {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status         MessageRequestStatus @default(pending)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  fromUserId     String               @map("from_user_id") @db.Uuid
  toUserId       String               @map("to_user_id") @db.Uuid
  conversationId String?              @map("conversation_id") @db.Uuid

  fromUser       User                 @relation("RequestFrom", fields: [fromUserId], references: [id])
  toUser         User                 @relation("RequestTo", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@map("message_requests")
}

model UserBlock {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  blockerId String @map("blocker_id") @db.Uuid
  blockedId String @map("blocked_id") @db.Uuid

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@map("user_blocks")
}

model Report {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  targetType String       @map("target_type") @db.VarChar(50)
  targetId   String       @map("target_id") @db.Uuid
  reason     String       @db.Text
  status     ReportStatus @default(pending)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  reporterId String       @map("reporter_id") @db.Uuid
  reporter   User         @relation("Reporter", fields: [reporterId], references: [id])

  @@index([status])
  @@index([reporterId])
  @@map("reports")
}

// ============================================================================
// 9. Knowledge Base
// ============================================================================

model KbFile {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ossKey       String?      @map("oss_key") @db.VarChar(512)
  localPath    String?      @map("local_path") @db.VarChar(512)
  fileUrl      String?      @map("file_url") @db.VarChar(512)
  fileName     String       @map("file_name") @db.VarChar(255)
  mimeType     String?      @map("mime_type") @db.VarChar(100)
  sizeBytes    BigInt?      @map("size_bytes")
  status       KbFileStatus @default(uploaded)
  errorMessage String?      @map("error_message") @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  ownerUserId  String       @map("owner_user_id") @db.Uuid
  owner        User         @relation(fields: [ownerUserId], references: [id])

  chunks       KbChunk[]

  @@index([ownerUserId])
  @@map("kb_files")
}

model KbChunk {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chunkIndex  Int      @map("chunk_index")
  text        String   @db.Text
  embedding   Unsupported("vector(1536)")?
  meta        Json?
  createdAt   DateTime @default(now()) @map("created_at")

  kbFileId    String   @map("kb_file_id") @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid

  kbFile      KbFile   @relation(fields: [kbFileId], references: [id], onDelete: Cascade)
  owner       User     @relation(fields: [ownerUserId], references: [id])

  @@index([ownerUserId])
  @@map("kb_chunks")
}

// ============================================================================
// 10. Audit Log
// ============================================================================

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action     String   @db.VarChar(100)
  targetType String?  @map("target_type") @db.VarChar(50)
  targetId   String?  @map("target_id") @db.Uuid
  metadata   Json?
  ip         String?  @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  actorId    String   @map("actor_id") @db.Uuid
  actor      User     @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetType, targetId])
  @@map("audit_logs")
}
