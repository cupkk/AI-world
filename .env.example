# ============================================================================
# AI-World Frontend — Environment Variables
# Copy to .env.local for local development
# ============================================================================

# Backend API base URL (leave empty if using Vite proxy)
# VITE_API_BASE_URL="http://localhost:3000"

# Demo helpers are enabled by default in local Vite dev, but should remain off in production.
VITE_ENABLE_DEMO_MODE="true"
VITE_ALLOW_DEMO_PREFILL="true"
